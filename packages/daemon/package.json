{
  "name": "@concerto/daemon",
  "version": "0.0.0",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "concerto": "./bin/concerto.mjs"
  },
  "scripts": {
    "build": "tsc",
    "dev": "concurrently -k -n tsc,nodemon \"tsc -w\" \"nodemon --watch dist --ext js dist/index.js\"",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@concerto/client": "*",
    "@concerto/core": "*",
    "@hono/node-server": "^1.19.9",
    "hono": "^4.12.1",
    "nanoid": "^5.1.6",
    "zod": "^4.1.13"
  }
}
